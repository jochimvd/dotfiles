font=JetBrainsMono Nerd Font Propo 11
width=460
height=160
margin=10
outer-margin=50,20,20,20
padding=12
border-size=2
border-radius=5
icons=1
max-icon-size=48
markup=1
actions=1
history=1
max-visible=5
max-history=50
anchor=top-right
layer=overlay
sort=-time
group-by=app-name,summary,body

background-color=#000000bf
text-color=#ffffffff
border-color=#ffffffff
progress-color=over #9ece6aff
format=<b>%s</b>\n<span color='#908caa'>%b</span>

default-timeout=10000
ignore-timeout=0

# Right-click a notification to dismiss it (not added to history)
on-button-right=dismiss --no-history

[urgency=low]
default-timeout=5000
border-color=#595959ff

[urgency=normal]
default-timeout=10000
border-color=#ffffffff

[urgency=critical]
default-timeout=0
border-color=#ff0000ff

[mode=do-not-disturb]
invisible=1
